# All env vars are optional — the site runs cleanly with none of them
# (ads and analytics simply don't load). Every var is public (client-side).

# Google AdSense publisher id, e.g. ca-pub-1234567890123456.
# Ads only render when this AND the matching slot id are set AND the
# visitor has accepted cookies.
NEXT_PUBLIC_ADSENSE_CLIENT=

# AdSense ad-unit slot ids (numeric), one per placement.
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_INCONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_RAIL=

# Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=

# Canonical site URL (no trailing slash). Used for metadata, sitemap,
# robots.txt, and JSON-LD. Defaults to the Vercel preview domain.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
