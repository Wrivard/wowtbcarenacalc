# All env vars are optional — the site runs cleanly with none of them
# (ads and analytics simply don't load). Every var is public (client-side).

# Google AdSense publisher id, e.g. ca-pub-1234567890123456.
# Ads only render when this AND the matching slot id are set AND the
# visitor has accepted cookies.
NEXT_PUBLIC_ADSENSE_CLIENT=

# AdSense ad-unit slot ids (numeric), one per placement.
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_INCONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_RAIL=

# Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=

# ── Live arena leaderboard (official Battle.net PvP Season API) ──────
# Optional. Without these the /leaderboard page shows labeled SAMPLE data.
# Register a free client at https://develop.battle.net, then set:
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
# Region: us or eu (default us).
BLIZZARD_REGION=us
# Verify these two against /data/wow/pvp-season/index for the current
# Anniversary progression before going live.
BLIZZARD_PVP_NAMESPACE=dynamic-classic-us
BLIZZARD_PVP_SEASON_ID=
# Optional shared secret to protect the cron endpoint.
CRON_SECRET=

# Canonical site URL (no trailing slash). Used for metadata, sitemap,
# robots.txt, and JSON-LD. Defaults to https://wowtbcarena.com.
# IMPORTANT: in the Vercel project env this MUST be the apex domain,
# never the *.vercel.app preview host, or canonical tags break SEO.
NEXT_PUBLIC_SITE_URL=https://wowtbcarena.com
