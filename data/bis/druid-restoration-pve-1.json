 "faq": [
  {
   "question": "Where does Restoration Druid Phase 1 BiS come from?",
   "answer": "From the gear worn by 359 top-ranked Restoration Druid healing parses on Warcraft Logs during Phase 1 (Karazhan, Gruul's Lair and Magtheridon), aggregated per slot — what high parsers actually equip, not a spreadsheet ideal."
  },
  {
   "question": "What are the highest-consensus Restoration Druid items in Phase 1?",
   "answer": "Idol of the Emerald Queen (94%), Forestlord Striders (69%), Mitts of the Treemender (67%). When an item sits above ~70% among top parsers, treat it as the priority drop to chase."
  },
  {
   "question": "Should I follow this list exactly for Phase 1?",
   "answer": "Use it as a loot-priority guide, not a checklist — expand each slot's alternatives, because second-choice items are often within a few percent and drop from entirely different bosses in Karazhan, Gruul's Lair and Magtheridon."
  }
