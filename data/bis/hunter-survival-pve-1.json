 "faq": [
  {
   "question": "Where does Survival Hunter Phase 1 BiS come from?",
   "answer": "From the gear worn by 336 top-ranked Survival Hunter DPS parses on Warcraft Logs during Phase 1 (Karazhan, Gruul's Lair and Magtheridon), aggregated per slot — what high parsers actually equip, not a spreadsheet ideal."
  },
  {
   "question": "What are the highest-consensus Survival Hunter items in Phase 1?",
   "answer": "Beast Lord Mantle (97%), Beast Lord Helm (94%), Beast Lord Handguards (92%). When an item sits above ~70% among top parsers, treat it as the priority drop to chase."
  },
  {
   "question": "Should I follow this list exactly for Phase 1?",
   "answer": "Use it as a loot-priority guide, not a checklist — expand each slot's alternatives, because second-choice items are often within a few percent and drop from entirely different bosses in Karazhan, Gruul's Lair and Magtheridon."
  }
